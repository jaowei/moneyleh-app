{
  "name": "moneyleh-app",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development bun run --hot src/index.ts",
    "dev:fe": "cd src/frontend && bun run dev",
    "start": "bun run src/index.ts",
    "generate:better-auth": "bunx --bun @better-auth/cli generate --output src/db/auth-schema.ts",
    "migrate:better-auth": "bunx --bun @better-auth/cli migrate",
    "generate:migrations": "bun drizzle-kit generate",
    "migrate:db": "bun run ./src/db/migrate.ts",
    "seed:db": "bun run ./src/db/seed.ts",
    "build:fe-dev": "cd src/frontend && bun run build:dev",
    "docker:start": "bun run migrate:db && bun run seed:db && bun run start"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@tensorflow-models/knn-classifier": "^1.2.6",
    "@tensorflow-models/universal-sentence-encoder": "^1.3.3",
    "@tensorflow/tfjs-node": "^4.22.0",
    "better-auth": "^1.5.5",
    "csv-parse": "^6.2.0",
    "dayjs": "^1.11.20",
    "drizzle-orm": "^0.44.7",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.8",
    "lefthook": "^2.1.4",
    "mupdf": "^1.27.0",
    "natural": "^8.1.1",
    "resend": "^4.8.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10"
  },
  "trustedDependencies": [
    "@tensorflow/tfjs-node"
  ]
}